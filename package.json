{
  "name": "primeiro-projeto",
  "version": "0.4.0",
  "description": "Aulas de Clean Archtecture",
  "main": "index.js",
  "engines": {
    "node": "12.16.3"
  },
  "scripts": {
    "start": "node dist/main/server.js",
    "debug": "nodemon -L --inspect=0.0.0.0:9222 --nolazy dist/main/server.js",
    "build": "rimraf dist && tsc",
    "dev": "sucrase-node src/main/server.ts",
    "docker:start": "npm run build && docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:restart": "npm run docker:stop && npm run docker:start",
    "test": "jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "jest --passWithNoTests --runInBand",
    "test:unit": "npm test -- --watch -c jest-unit.config.js",
    "test:integration": "npm test -- --watch -c jest-integration.config.js",
    "test:staged": "npm test -- --findRelatedTests",
    "test:ci": "npm test -- --coverage",
    "test:coveralls": "npm run test:ci && coveralls < coverage/lcov.info"
  },
  "repository": {
    "type": "git",
    "url": "git"
  },
  "keywords": [
    "plataformabr"
  ],
  "author": "Plataforma BR",
  "license": "ISC",
  "homepage": "",
  "devDependencies": {
    "@shelf/jest-mongodb": "^1.1.5",
    "@types/bcrypt": "^3.0.0",
    "@types/express": "^4.17.6",
    "@types/jest": "^25.2.1",
    "@types/jsonwebtoken": "^8.3.9",
    "@types/mongodb": "^3.5.16",
    "@types/node": "^14.0.1",
    "@types/supertest": "^2.0.9",
    "@types/validator": "^13.0.0",
    "@typescript-eslint/eslint-plugin": "^2.33.0",
    "@typescript-eslint/parser": "^2.33.0",
    "coveralls": "^3.1.0",
    "eslint": "^7.0.0",
    "eslint-config-standard": "^14.1.1",
    "eslint-config-standard-with-typescript": "^16.0.0",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "fast-glob": "^3.2.2",
    "git-commit-msg-linter": "^2.4.2",
    "husky": "^4.2.5",
    "jest": "^26.0.1",
    "lint-staged": "^10.2.2",
    "mongodb-memory-server": "^6.6.0",
    "nodemon": "^2.0.3",
    "rimraf": "^3.0.2",
    "sucrase": "^3.14.0",
    "supertest": "^4.0.2",
    "ts-jest": "^25.5.1",
    "typescript": "^3.9.2"
  },
  "dependencies": {
    "bcrypt": "^5.0.0",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^3.5.7",
    "npm": "^6.14.5",
    "validator": "^13.0.0"
  }
}
